# --- Control-plane API ---
HTTP_ADDR=:8080

# Postgres
DATABASE_URL=postgres://vodstack:vodstack@postgres:5432/vodstack?sslmode=disable

# Redis (asynq broker)
REDIS_ADDR=redis:6379

# MinIO (S3-compatible object store)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET=vodstack-videos

# Public base URL where HLS is served from (origin/edge).
# /play builds <PUBLIC_BASE_URL>/hls/{videoId}/master.m3u8
PUBLIC_BASE_URL=http://localhost:8081

# HMAC secret for signed URLs (Phase 2). Generate a long random value in prod.
TOKEN_SECRET=dev-insecure-change-me

# Presigned upload URL TTL (seconds)
UPLOAD_URL_TTL=3600

# --- Worker ---
# Local scratch dir for downloads + ffmpeg output
SCRATCH_DIR=/scratch
# Number of concurrent transcode jobs per worker
WORKER_CONCURRENCY=2
# Path to ffmpeg / ffprobe binaries
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# --- Dev seed ---
# A library + api key seeded on first API start (dev convenience).
SEED_LIBRARY_ID=default
SEED_LIBRARY_API_KEY=dev-library-key
