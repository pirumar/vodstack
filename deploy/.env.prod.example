# vodstack — production env (fixed IP, HTTP).
#
# 1) Copy this file:        cp deploy/.env.prod.example deploy/.env.prod
# 2) Fill the values below  (at least FIXED_IP + every secret)
# 3) Start:
#      docker compose --env-file deploy/.env.prod -f deploy/docker-compose.yml up --build -d
#
# .env.prod is git-ignored. NEVER commit real secrets.
# Generate a strong secret with:  openssl rand -hex 32

# ----------------------------------------------------------------------------
# Network — the server's fixed/public IP. Only edge(8082), web(8090) and
# api(8080) are published on this IP; everything else stays internal.
# ----------------------------------------------------------------------------
FIXED_IP=203.0.113.10

# Bind public-facing services to the fixed IP (leave as-is once FIXED_IP is set).
PUBLIC_IP=${FIXED_IP}

# Ops/debug services (MinIO, origin, Prometheus, Grafana) bind to localhost only
# -> reachable solely via SSH tunnel, never from the internet. Keep 127.0.0.1.
OPS_BIND=127.0.0.1

# Restart containers automatically (survives reboot / crash).
RESTART=unless-stopped

# ----------------------------------------------------------------------------
# Host ports — moved to a dedicated 38xxx/39xxx block so they never collide
# with other stacks already on this server (redis 6379, open-webui 1453,
# rabbitmq 15672, mongo 27017, seq 5341, etc.). Change freely if needed; the
# values below just have to be unique on the host.
# Internal services (postgres/redis/whisper) publish NO host port, so vodstack's
# own redis does NOT conflict with the server's redis on 6379.
# ----------------------------------------------------------------------------
# Public (bound to FIXED_IP):
API_PORT=38080
EDGE_PORT=38082
WEB_PORT=38090
# Ops/debug (bound to 127.0.0.1, SSH tunnel only):
ORIGIN_PORT=38081
MINIO_API_PORT=39000
MINIO_CONSOLE_PORT=39001
PROMETHEUS_PORT=39092
GRAFANA_PORT=33001

# ----------------------------------------------------------------------------
# Public URLs baked into responses (must use the fixed IP so browsers reach them)
#   PUBLIC_BASE_URL -> edge   (signed HLS playback)
#   EMBED_BASE_URL  -> api    (iframe embed snippets)
#   KEY_BASE_URL    -> api    (AES-128 decryption key URIs in playlists)
# Update the IP in all three, and keep the ports in sync with EDGE_PORT/API_PORT
# above. (If you later add a domain, switch to https://...)
#
# >>> CLOUDFLARE CDN: when using the Cloudflare Tunnel (see below + deploy/CDN.md)
#     set these to your HTTPS hostnames instead and they "just work" — the signed
#     URLs, embed snippets and AES key URIs all point at Cloudflare automatically:
#       PUBLIC_BASE_URL=https://stream.example.com   (edge / playback)
#       EMBED_BASE_URL=https://api.example.com        (iframe embeds)
#       KEY_BASE_URL=https://api.example.com          (AES-128 key URIs)
#     NOTE: KEY_BASE_URL is baked into a playlist when a video is encrypted, so
#     set it BEFORE encrypting (re-encrypt older videos to update their key URI).
# ----------------------------------------------------------------------------
PUBLIC_BASE_URL=http://203.0.113.10:38082
EMBED_BASE_URL=http://203.0.113.10:38080
KEY_BASE_URL=http://203.0.113.10:38080

# ----------------------------------------------------------------------------
# Cloudflare CDN (optional). Leave blank to run without a CDN.
# To enable: create a Tunnel in the Cloudflare Zero Trust dashboard, paste its
# token here, and start with `--profile cdn`. Full steps in deploy/CDN.md.
# In tunnel mode nothing needs a public host port — you can set PUBLIC_IP and
# OPS_BIND both to 127.0.0.1 so the server exposes NOTHING to the internet
# (Cloudflare reaches the services over the compose network, outbound-only).
# ----------------------------------------------------------------------------
CLOUDFLARE_TUNNEL_TOKEN=

# ----------------------------------------------------------------------------
# Secrets — CHANGE EVERY ONE of these for production.
# ----------------------------------------------------------------------------
# Signed-URL HMAC secret. MUST be identical for api and edge. openssl rand -hex 32
TOKEN_SECRET=CHANGE_ME_openssl_rand_hex_32
# Set only while rotating TOKEN_SECRET (old value); otherwise leave empty.
TOKEN_SECRET_PREVIOUS=

# Admin panel login password (https://<ip>:8090).
ADMIN_PASSWORD=CHANGE_ME_admin_password

# Library API key (Bearer token for the public library API).
SEED_LIBRARY_API_KEY=CHANGE_ME_library_key

# Postgres credentials.
PG_USER=vodstack
PG_PASSWORD=CHANGE_ME_pg_password
PG_DB=vodstack

# MinIO (object store) root credentials.
MINIO_USER=vodstack-minio
MINIO_PASSWORD=CHANGE_ME_minio_password
MINIO_BUCKET=vodstack-videos

# Grafana admin password (reachable only via SSH tunnel).
GRAFANA_PASSWORD=CHANGE_ME_grafana_password

# HuggingFace token for the whisper sidecar's model pull (optional but
# recommended for rate limits). Create one at https://huggingface.co/settings/tokens.
HF_TOKEN=

# ----------------------------------------------------------------------------
# Tuning (optional)
# ----------------------------------------------------------------------------
# Concurrent transcode jobs per worker (raise on bigger CPUs).
WORKER_CONCURRENCY=2

# ----------------------------------------------------------------------------
# Resource isolation (single-host hardening) — prevents a traffic/transcode
# spike from starving the box and dropping the Cloudflare tunnel (Error 1033).
#
# cpu_shares are RELATIVE weights (default 1024). Under CPU contention the
# scheduler hands out time in proportion: cloudflared (4096) and api (2048) win,
# the background worker/whisper (256) yield. They cost nothing when the box is
# idle — only matter when everything competes. Box-size independent; safe to
# leave as-is. Tune only if you understand the trade-off.
CLOUDFLARED_CPU_SHARES=4096
API_CPU_SHARES=2048
WORKER_CPU_SHARES=256
WHISPER_CPU_SHARES=256

# Hard RAM ceilings on the two memory hogs so a runaway job is OOM-killed (and
# auto-restarted) instead of taking down the whole box. Set these to fit YOUR
# server: run `docker stats` during a transcode and leave headroom. Defaults
# suit a ~8 GB box; LOWER them on a 4 GB box, RAISE for 4K / larger models.
WORKER_MEM_LIMIT=3g
WHISPER_MEM_LIMIT=4g
# Presigned upload URL TTL (seconds).
UPLOAD_URL_TTL=3600
# Seed/admin library id.
SEED_LIBRARY_ID=default
ADMIN_LIBRARY_ID=default
