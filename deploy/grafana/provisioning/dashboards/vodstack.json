{
  "title": "vodstack",
  "uid": "vodstack",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP request rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(vodstack_http_requests_total[1m])) by (route)", "legendFormat": "{{route}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP p95 latency (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(vodstack_http_request_duration_seconds_bucket[5m])) by (le, route))", "legendFormat": "{{route}}" }
      ]
    },
    {
      "type": "stat",
      "title": "Transcodes (success)",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "targets": [{ "expr": "sum(vodstack_transcode_total{result=\"success\"})" }]
    },
    {
      "type": "stat",
      "title": "Transcodes (failed)",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "targets": [{ "expr": "sum(vodstack_transcode_total{result=\"failed\"})" }]
    },
    {
      "type": "timeseries",
      "title": "Transcode duration p90 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.90, sum(rate(vodstack_transcode_duration_seconds_bucket[10m])) by (le))", "legendFormat": "p90" }
      ]
    }
  ]
}
